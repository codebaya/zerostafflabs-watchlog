# WatchLog configuration — copy to .env and fill in values

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# AI Models
# Options: "ollama", "transformers", "mock"
QWEN_BACKEND=ollama
QWEN_MODEL=qwen2.5vl:7b
YOLO_MODEL_PATH=./models/yolo26.pt   # or leave empty to auto-download
YOLO_CONFIDENCE=0.5

# Storage
DATABASE_URL=sqlite+aiosqlite:///./watchlog.db
CLIP_STORAGE_DIR=./clips

# Night batch window (24h format, local time)
BATCH_START_HOUR=2
BATCH_END_HOUR=6

# Morning report
REPORT_HOUR=8
REPORT_MINUTE=0

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
